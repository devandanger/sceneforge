{
  "version": "0.1",
  "template": "naprej",
  "format": {
    "platform": "tiktok",
    "width": 1080,
    "height": 1920,
    "fps": 30,
    "paddingPercent": 8
  },
  "theme": {
    "brand": "SceneForge",
    "backgroundColor": "#F4F7F9",
    "primaryTextColor": "#121212",
    "accentColor": "#2B6FD9",
    "fontFamily": "Inter",
    "layout": {
      "showBrandMark": false,
      "showTopRule": false,
      "backgroundStyle": "flat"
    }
  },
  "audio": {
    "music": {
      "mode": "none"
    },
    "captions": {
      "mode": "scene"
    }
  },
  "scenes": [
    {
      "id": "hook",
      "type": "text",
      "duration": 2,
      "transition": "fade",
      "title": "One JSON file.",
      "subtitle": "A short vertical video.",
      "align": "center",
      "verticalAlign": "center"
    },
    {
      "id": "image",
      "type": "image",
      "duration": 3,
      "transition": "fade",
      "image": "./assets/brand-card.svg",
      "caption": "Local assets only. No AI services.",
      "overlays": [
        {
          "type": "group",
          "position": "bottom-left",
          "direction": "vertical",
          "align": "start",
          "gapPercent": 1,
          "maxWidthPercent": 70,
          "children": [
            {
              "type": "text",
              "text": "Overlay group",
              "fontSizePercent": 4.8,
              "color": "#FFFFFF",
              "backgroundColor": "#121212",
              "paddingPercent": 1
            },
            {
              "type": "text",
              "text": "Stacked text without arbitrary CSS.",
              "fontSizePercent": 3.2,
              "color": "#121212",
              "backgroundColor": "#FFFFFF",
              "paddingPercent": 0.8
            }
          ]
        }
      ]
    },
    {
      "id": "cta",
      "type": "cta",
      "duration": 2,
      "transition": "fade",
      "title": "SceneForge",
      "subtitle": "Render repeatable videos from JSON.",
      "cta": "Try the CLI"
    }
  ]
}
