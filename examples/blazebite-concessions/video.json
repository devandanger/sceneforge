{
  "version": "0.1",
  "template": "blazebite",
  "format": {
    "platform": "tiktok",
    "width": 1080,
    "height": 1920,
    "fps": 30
  },
  "theme": {
    "brand": "BlazeBite",
    "backgroundColor": "#F4F7F9",
    "primaryTextColor": "#101820",
    "accentColor": "#FF4F1F",
    "fontFamily": "Inter"
  },
  "audio": {
    "voiceover": {
      "provider": "elevenlabs",
      "voiceId": "default",
      "script": "Long concession lines cost sales. BlazeBite helps venues move orders faster from menu to pickup."
    },
    "music": {
      "mode": "none"
    },
    "captions": {
      "mode": "scene"
    }
  },
  "scenes": [
    {
      "id": "problem",
      "type": "text",
      "duration": 3,
      "transition": "fade",
      "title": "Long lines cost sales.",
      "subtitle": "Game-day concessions need faster ordering."
    },
    {
      "id": "ops",
      "type": "image",
      "duration": 3,
      "transition": "fade",
      "image": "./assets/venue-counter.svg",
      "caption": "Built for busy venue operations."
    },
    {
      "id": "screen",
      "type": "screenshot",
      "duration": 4,
      "transition": "slide-up",
      "image": "./assets/order-screen.svg",
      "title": "Orders move from menu to pickup"
    },
    {
      "id": "cta",
      "type": "cta",
      "duration": 2,
      "transition": "fade",
      "title": "BlazeBite",
      "subtitle": "Mobile ordering for venues.",
      "cta": "Book a demo"
    }
  ]
}
