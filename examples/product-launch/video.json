{
  "version": "0.1",
  "template": "light",
  "format": {
    "platform": "tiktok",
    "width": 1080,
    "height": 1920,
    "fps": 30
  },
  "theme": {
    "brand": "Acme",
    "backgroundColor": "#F5F3EF",
    "primaryTextColor": "#1A1A1A",
    "accentColor": "#2F6BFF",
    "fontFamily": "Inter",
    "layout": {
      "showBrandMark": true,
      "brandMarkText": "Acme",
      "showTopRule": true,
      "backgroundStyle": "soft"
    }
  },
  "audio": {
    "voiceover": {
      "provider": "elevenlabs",
      "voiceId": "default",
      "script": "Meet Acme, the simplest way to turn ideas into action. Plan, track, and ship in one place."
    },
    "music": {
      "mode": "none"
    },
    "captions": {
      "mode": "scene"
    }
  },
  "scenes": [
    {
      "id": "hook",
      "type": "text",
      "duration": 3,
      "transition": "fade",
      "title": "Ship faster.",
      "subtitle": "One workspace for your whole team.",
      "titleColor": "#2F6BFF"
    },
    {
      "id": "hero",
      "type": "image",
      "duration": 4,
      "transition": "fade",
      "image": "./assets/hero.svg",
      "caption": "Built for focused teams."
    },
    {
      "id": "app",
      "type": "screenshot",
      "duration": 4,
      "transition": "slide-up",
      "image": "./assets/app-screenshot.svg",
      "title": "Everything in one view"
    },
    {
      "id": "cta",
      "type": "cta",
      "duration": 3,
      "transition": "fade",
      "title": "Acme",
      "subtitle": "Get started in minutes.",
      "cta": "Start free"
    }
  ]
}
