{
  "name": "sceneforge",
  "version": "0.3.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devandanger/sceneforge.git"
  },
  "homepage": "https://github.com/devandanger/sceneforge#readme",
  "bugs": "https://github.com/devandanger/sceneforge/issues",
  "bin": {
    "sceneforge": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "sceneforge": "tsx apps/cli/src/index.ts",
    "validate": "tsx apps/cli/src/index.ts validate",
    "tts": "tsx apps/cli/src/index.ts tts",
    "preview": "tsx apps/cli/src/index.ts preview",
    "render": "tsx apps/cli/src/index.ts render",
    "build": "node scripts/build.mjs",
    "check": "tsc --noEmit && npm run check:schema",
    "check:schema": "tsx scripts/check-schema-descriptions.ts",
    "check:package": "node scripts/check-package.mjs",
    "test": "tsx --test \"apps/**/*.test.ts\" \"packages/**/*.test.ts\"",
    "prepublishOnly": "npm run check && npm test && npm run check:package && npm run build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@remotion/cli": "^4.0.300",
    "@remotion/renderer": "^4.0.300",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remotion": "^4.0.300",
    "zod": "4.3.6",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.8",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
